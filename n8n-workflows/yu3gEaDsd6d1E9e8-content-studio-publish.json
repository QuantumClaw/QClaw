    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Combine merged per-branch fields with csj context, build patch body + telegram.\nconst csj = $('SELECT csj').first().json;\nconst merged = $input.first().json;\n\nconst failedSurfaces = [];\nif (merged.wp_status !== 'success') failedSurfaces.push('wordpress');\nif (merged.li_status !== 'success') failedSurfaces.push('linkedin');\nif (merged.yt_status !== 'success') failedSurfaces.push('youtube');\nconst allSuccess = failedSurfaces.length === 0;\n\nconst publishMetadata = {\n  wp_status: merged.wp_status || null,\n  wp_slug: merged.wp_slug || null,\n  wp_url: merged.wp_url || null,\n  wp_error: merged.wp_error || null,\n  li_status: merged.li_status || null,\n  li_post_id: merged.li_post_id || null,\n  li_url: merged.li_url || null,\n  li_error: merged.li_error || null,\n  li_raw_response: merged.li_raw_response || null,\n  yt_status: merged.yt_status || null,\n  yt_url: merged.yt_url || null,\n  yt_error: merged.yt_error || null,\n  yt_raw_response: merged.yt_raw_response || null,\n  failed_surfaces: failedSurfaces,\n};\n\n// Build telegram message\nconst title = csj.episode_title || '<no title>';\nconst tick = (s) => s === 'success' ? '\\u2705' : '\\u274c';\nlet tg;\nif (allSuccess) {\n  tg = '\\ud83d\\udce2 Episode published: ' + title +\n       '\\n\\n\\u2705 WordPress: ' + (merged.wp_slug || merged.wp_url || '(no slug)') +\n       '\\n\\u2705 LinkedIn: ' + (merged.li_url || merged.li_post_id || '(posted, no url returned)') +\n       '\\n\\u2705 YouTube: ' + merged.yt_url +\n       '\\n\\ncsj: ' + csj.id;\n} else {\n  tg = '\\ud83d\\udce2 Episode published with errors: ' + title + '\\n\\n' +\n       tick(merged.wp_status) + ' WordPress' +\n         (merged.wp_status === 'success' ? ': ' + (merged.wp_slug || merged.wp_url || '(no slug)') : ': ' + (merged.wp_error || '(error)')) +\n       '\\n' + tick(merged.li_status) + ' LinkedIn' +\n         (merged.li_status === 'success' ? ': ' + (merged.li_url || merged.li_post_id || '(posted)') : ': ' + (merged.li_error || '(error)')) +\n       '\\n' + tick(merged.yt_status) + ' YouTube' +\n         (merged.yt_status === 'success' ? ': ' + merged.yt_url : ': ' + (merged.yt_error || '(error)')) +\n       '\\n\\nManual fix needed for: ' + failedSurfaces.join(', ') +\n       '\\ncsj: ' + csj.id;\n}\n\nreturn [{\n  json: {\n    csj_id: csj.id,\n    episode_title: title,\n    all_success: allSuccess,\n    failed_surfaces: failedSurfaces,\n    publish_metadata: publishMetadata,\n    // PATCH-shape fields for csj\n    patch_body: {\n      status: 'full_complete',\n      published_at: new Date().toISOString(),\n      publish_metadata: publishMetadata,\n      wordpress_slug: merged.wp_status === 'success' ? merged.wp_slug : csj.wordpress_slug,\n      wordpress_status: merged.wp_status === 'success' ? 'publish' : csj.wordpress_status,\n      wordpress_post_url: merged.wp_status === 'success' ? merged.wp_url : csj.wordpress_post_url,\n      linkedin_post_id: merged.li_status === 'success' ? merged.li_post_id : csj.linkedin_post_id,\n      linkedin_post_url: merged.li_status === 'success' ? merged.li_url : csj.linkedin_post_url,\n      linkedin_posted_at: merged.li_status === 'success' ? new Date().toISOString() : csj.linkedin_posted_at,\n    },\n    telegram_text: tg,\n  }\n}];\n"
      },
      "name": "Build Publish Summary",

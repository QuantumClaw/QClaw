    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Build LinkedIn post text. Workflow A's Generate LinkedIn Post embedded\n// the Buzzsprout URL inline at A-time via Claude. Defensive: if the trailing\n// \"\ud83c\udfa7 Listen here:\" line has NO URL after it, substitute csj.buzzsprout_url.\n// Otherwise post verbatim.\nconst csj = $input.first().json;\nconst post = csj.linkedin_post;\nconst buzzUrl = csj.buzzsprout_url;\n\nif (!post) {\n  throw new Error('linkedin_post is empty \u2014 Workflow A did not generate text');\n}\n\nconst trailingPattern = /\ud83c\udfa7\\s*Listen here:\\s*$/;\nif (trailingPattern.test(post)) {\n  if (!buzzUrl) {\n    throw new Error('Trailing placeholder present but buzzsprout_url is empty');\n  }\n  return [{\n    json: {\n      ...csj,\n      linkedinText: post.replace(trailingPattern, `\ud83c\udfa7 Listen here: ${buzzUrl}`)\n    }\n  }];\n}\n\n// Otherwise post verbatim \u2014 Claude embedded URL inline already\nreturn [{ json: { ...csj, linkedinText: post } }];\n"
      },
      "name": "Build LinkedIn Text",
      "type": "n8n-nodes-base.code",

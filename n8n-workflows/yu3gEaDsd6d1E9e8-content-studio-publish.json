        "query": "update public.content_studio_jobs\nset buzzsprout_url = 'https://www.buzzsprout.com/1946225/episodes/' || buzzsprout_episode_id,\n    updated_at = now()\nwhere id = '{{ $('SELECT csj').first().json.id }}'::uuid\n  and buzzsprout_episode_id is not null\nreturning *;",

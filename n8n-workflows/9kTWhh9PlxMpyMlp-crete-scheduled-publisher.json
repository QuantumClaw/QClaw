        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ content_id: $json.id }) }}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "a0000000-0000-0000-0000-000000000005",
      "name": "Trigger Publish",

    {
      "parameters": {
        "jsCode": "// Always-runs summary node. Input is the Schedule's single tick item.\n// QAD has already completed by this point (declared earlier in fan-out list).\nconst rows = $('Query Approved Due').all();\nreturn [{ json: {\n  count: rows.length,\n  ids: rows.map(r => r.json.id),\n  timestamp: new Date().toISOString()\n} }];"
      },

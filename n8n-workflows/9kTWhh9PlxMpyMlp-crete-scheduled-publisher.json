        "queryParameters": {
          "parameters": [
            {
              "name": "select",
              "value": "*"
            },
            {
              "name": "status",
              "value": "eq.approved"
            },
            {
              "name": "scheduled_for",
              "value": "lte.now()"
            },
            {
              "name": "order",
              "value": "scheduled_for.asc"
            },
            {
              "name": "limit",
              "value": "10"
            },
            {
              "name": "publish_attempts",
              "value": "lt.3"

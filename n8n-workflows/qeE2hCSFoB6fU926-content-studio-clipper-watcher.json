        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({chat_id: 1375806243, text: '\\u26a0\\ufe0f Clipper failed: ' + ($('Switch Clip Status').item.json.csj_episode_title || '<no title>') + '\\n\\nReason: ' + ($('Switch Clip Status').item.json.cj_error_message || '<no error message>') + '\\n\\nPodcast can still publish; clips skipped.' + '\\ncsj: ' + ($('Switch Clip Status').item.json.csj_id || '<no id>'), parse_mode: 'HTML'}) }}",
        "options": {}

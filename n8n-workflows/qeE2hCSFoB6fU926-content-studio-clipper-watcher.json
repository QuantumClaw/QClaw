    {
      "parameters": {
        "operation": "executeQuery",
        "query": "update public.content_studio_jobs\nset poll_count = coalesce(poll_count, 0) + 1,\n    updated_at = now()\nwhere id = '{{ $json.csj_id }}'::uuid\nreturning id, poll_count;",
        "options": {}
      },
      "name": "Patch: Increment Poll",
      "type": "n8n-nodes-base.postgres",

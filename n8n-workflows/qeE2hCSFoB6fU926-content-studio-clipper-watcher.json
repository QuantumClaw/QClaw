        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({chat_id: 1375806243, text: '\\u23f1\\ufe0f Clipper timeout: ' + ($('Switch Clip Status').item.json.csj_episode_title || '<no title>') + '\\n\\nReached 60 polls (30min). Clip job may still complete async \u2014 check clip_jobs/' + ($('Switch Clip Status').item.json.csj_clip_job_id || '<no id>') + '.' + '\\ncsj: ' + ($('Switch Clip Status').item.json.csj_id || '<no id>'), parse_mode: 'HTML'}) }}",
        "options": {}
